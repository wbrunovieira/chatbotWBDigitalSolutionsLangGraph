version: '3.8'

networks:
  {{ docker_network }}:
    external: true
  # External networks of the sibling stacks, so the chatbot can reach the WB-CRM and the
  # Evolution (WhatsApp) API by service name, internally — no Cloudflare hop. These already
  # exist on the host (created by the wb-crm / evolution compose stacks).
  wb_crm_net:
    external: true
    name: wb-crm_default
  evolution_net:
    external: true
    name: evolution_evolution_network

volumes:
  qdrant_data:
    driver: local
  chatbot_redis_data:
    driver: local

services:
  qdrant:
    image: qdrant/qdrant:latest
    container_name: chatbot_qdrant
    restart: always
    # NO `ports:` — Qdrant is reachable only from the Docker network.
    #
    # This is the load-bearing change, not the UFW rules in the playbook: publishing a
    # port makes Docker write straight to the DOCKER-USER iptables chain, which UFW
    # does not filter, so a `ufw deny 6333` would NOT have closed this. Until now,
    # 6333 was open to the internet with an empty API key: anyone could read the
    # chat_logs collection (every lead conversation) and poison company_info to make
    # the bot hand out an attacker's contact details.
    environment:
      - QDRANT__SERVICE__ENABLE_TLS=false
      - QDRANT__SERVICE__API_KEY=${QDRANT_API_KEY}
    volumes:
      - qdrant_data:/qdrant/storage
    networks:
      - {{ docker_network }}
    healthcheck:
      test: ["CMD-SHELL", "bash -c '</dev/tcp/localhost/6333 || exit 1'"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  redis-chatbot:
    image: redis:7-alpine
    container_name: chatbot_redis
    restart: always
    # NO `ports:` — same reasoning as Qdrant above. Redis was open on the internet
    # with no password. Beyond reading the cache, the cache key is a plain
    # sha256("{message}_{language}_{current_page}") and therefore predictable, so an
    # attacker could precompute the key for a common question and write a poisoned
    # answer that the bot would then serve to real leads for the full 7-day TTL.
    command: ["redis-server", "--requirepass", "${REDIS_PASSWORD}"]
    volumes:
      - chatbot_redis_data:/data
    networks:
      - {{ docker_network }}
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASSWORD}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  chatbot:
    build:
      context: .
      dockerfile: Dockerfile
    image: wb-chatbot:latest
    container_name: chatbot_app
    restart: always
    # Bound to loopback: only nginx (on the host) can reach the app. Previously this
    # was published on 0.0.0.0, so http://<vps-ip>:{{ app_port }}/chat bypassed nginx
    # entirely — which would have made any nginx- or Cloudflare-level rate limit
    # decorative. It also means X-Real-IP can now be trusted (see security.py).
    ports:
      - "127.0.0.1:{{ app_port }}:8000"
    environment:
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
      # Secondary LLM provider (providers/llm.py) — blank disables failover.
      - FALLBACK_API_URL=${FALLBACK_API_URL}
      - FALLBACK_API_KEY=${FALLBACK_API_KEY}
      - FALLBACK_MODEL=${FALLBACK_MODEL}
      - QDRANT_HOST=http://chatbot_qdrant:6333
      - QDRANT_API_KEY=${QDRANT_API_KEY}
      - REDIS_HOST=redis-chatbot
      - REDIS_PORT=6379
      - REDIS_DB=0
      - REDIS_PASSWORD=${REDIS_PASSWORD}
      - APP_ENV=production
      - ADMIN_API_TOKEN=${ADMIN_API_TOKEN}
      # Abuse and cost controls (see security.py)
      - DAILY_SPEND_LIMIT_USD=${DAILY_SPEND_LIMIT_USD}
      - DAILY_SPEND_LIMIT_PER_IP_USD=${DAILY_SPEND_LIMIT_PER_IP_USD}
      - SPEND_ALERT_THRESHOLD=${SPEND_ALERT_THRESHOLD}
      - RATE_LIMIT_ENABLED=${RATE_LIMIT_ENABLED}
      - RATE_LIMIT_PER_MINUTE=${RATE_LIMIT_PER_MINUTE}
      - RATE_LIMIT_PER_HOUR=${RATE_LIMIT_PER_HOUR}
      - MAX_MESSAGE_LENGTH=${MAX_MESSAGE_LENGTH}
      # Agent tools (see tools.py). Token comes from a secret; Evolution vars are optional
      # (blank -> the WhatsApp notify is skipped, the lead still persists).
      - WBCRM_BASE_URL=${WBCRM_BASE_URL}
      - WBCRM_API_TOKEN=${WBCRM_API_TOKEN}
      - LEAD_SOURCE_GROUP=${LEAD_SOURCE_GROUP}
      - BOOKING_URL=${BOOKING_URL}
      - WHATSAPP_CONTACT=${WHATSAPP_CONTACT}
      - EVOLUTION_API_URL=${EVOLUTION_API_URL}
      - EVOLUTION_API_KEY=${EVOLUTION_API_KEY}
      - EVOLUTION_INSTANCE=${EVOLUTION_INSTANCE}
      - MY_WHATSAPP_NUMBER=${MY_WHATSAPP_NUMBER}
      # Low-credit alert (providers/balance.py, run daily by cron) — WhatsApp the team
      # when the DeepSeek balance drops below this USD amount.
      - DEEPSEEK_BALANCE_ALERT_THRESHOLD=${DEEPSEEK_BALANCE_ALERT_THRESHOLD}
    depends_on:
      - qdrant
      - redis-chatbot
    networks:
      - {{ docker_network }}
      - wb_crm_net
      - evolution_net
    volumes:
      - {{ install_path }}/logs:/app/logs
    healthcheck:
      # Use Python (present in the image) not curl — the slim base has no curl, which
      # made this check always fail and marked the container perpetually unhealthy.
      # Require an exact 200: urlopen accepts any 2xx, so assert the status explicitly.
      test: ["CMD", "python", "-c", "import sys,urllib.request; sys.exit(0 if urllib.request.urlopen('http://localhost:8000/health', timeout=5).status == 200 else 1)"]
      interval: 30s
      timeout: 10s
      retries: 3
      # Generous: on a first/changed-KB boot the startup lifespan downloads the ONNX
      # embedding model and ingests the KB before serving, which can take tens of seconds.
      start_period: 90s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"
