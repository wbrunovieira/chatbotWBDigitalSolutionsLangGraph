# WB Digital Solutions Chatbot - Production Environment
# Generated by Ansible on {{ ansible_date_time.date }}
#
# The secrets below are generated once on the first deploy and persisted under
# {{ install_path }}/.secrets/ (mode 0600), so re-running the playbook does not rotate
# them out from under the running containers.

# DeepSeek API
DEEPSEEK_API_KEY={{ deepseek_api_key }}

# Qdrant Vector Database (Docker network only; no longer published to the host)
QDRANT_HOST=http://chatbot_qdrant:6333
QDRANT_API_KEY={{ resolved_qdrant_api_key }}

# Redis Cache (Docker network only; no longer published to the host)
REDIS_HOST=redis-chatbot
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD={{ resolved_redis_password }}

# Langfuse
LANGFUSE_PUBLIC_KEY={{ langfuse_public_key | default('') }}
LANGFUSE_SECRET_KEY={{ langfuse_secret_key | default('') }}
LANGFUSE_HOST={{ langfuse_host | default('https://calendar-langfuse.wbdigitalsolutions.com') }}

# Application Settings
APP_ENV=production
LOG_LEVEL=info

# Operator-only endpoints (/usage-report). Server-to-server, never reaches a browser.
ADMIN_API_TOKEN={{ resolved_admin_api_token }}

# --- Abuse and cost controls (see security.py) ---

# Hard ceiling on DeepSeek spend per UTC day. Past this, /chat returns 503 rather than
# calling the LLM — the backstop that stops abuse from turning into an invoice.
DAILY_SPEND_LIMIT_USD={{ daily_spend_limit_usd | default('5.0') }}

# Per-IP slice of the daily budget, so a single abuser cannot burn the whole cap and
# take the chatbot offline for every real visitor.
DAILY_SPEND_LIMIT_PER_IP_USD={{ daily_spend_limit_per_ip_usd | default('0.50') }}

# Fraction of the daily cap that logs a one-per-day ERROR alert.
SPEND_ALERT_THRESHOLD={{ spend_alert_threshold | default('0.70') }}

RATE_LIMIT_ENABLED={{ rate_limit_enabled | default('true') }}
RATE_LIMIT_PER_MINUTE={{ rate_limit_per_minute | default('10') }}
RATE_LIMIT_PER_HOUR={{ rate_limit_per_hour | default('100') }}

# Caps token amplification: one /chat request fans out into up to 3 DeepSeek calls.
MAX_MESSAGE_LENGTH={{ max_message_length | default('1000') }}
