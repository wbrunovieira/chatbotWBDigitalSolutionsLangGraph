upstream chatbot_backend {
    server localhost:{{ app_port }};
}

server {
    listen 80;
    server_name {{ chatbot_domain }};

    location / {
        # No CORS handling here on purpose: the FastAPI app is the single source of
        # CORS headers (strict allowlist, no credentials). The previous block
        # reflected $http_origin — it echoed ANY origin back, including an attacker's
        # — and preflight is now handled by the app's CORSMiddleware.
        proxy_pass http://chatbot_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Hard cap on request body: /chat messages are <=1000 chars. This is the
        # outer guard of the token-amplification defense (the app also enforces
        # MAX_MESSAGE_LENGTH); 64k leaves room for headers without allowing a
        # multi-megabyte body to reach the app at all.
        client_max_body_size 64k;
    }

    location /health {
        proxy_pass http://chatbot_backend/health;
        access_log off;
    }
}