[chatbot_server]
wb_server ansible_host=45.90.123.190 ansible_user=root ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[chatbot_server:vars]
ansible_python_interpreter=/usr/bin/python3

# Domínio e SSL
chatbot_domain=chatbot.wbdigitalsolutions.com
ssl_email=admin@wbdigitalsolutions.com
enable_ssl=true

# Variáveis de ambiente para produção
deepseek_api_key=YOUR_DEEPSEEK_API_KEY_HERE
# Note: qdrant_api_key, redis_password and admin_api_token are NOT set here. They are
# generated on the target on first deploy and persisted under {{ install_path }}/.secrets/
# (mode 0600). Re-running the playbook reuses them instead of rotating them.

# Configurações de portas
# These ports are bound to loopback (app) or kept off the host entirely (Qdrant,
# Redis). UFW additionally denies them from the internet as defense in depth.
app_port=8001
qdrant_port=6333
redis_port=6380

# Configurações de rede Docker
docker_network=wb_network

# Caminhos de instalação
install_path=/root/chatbot
data_path=/root/chatbot/volumes

# --- Stage 3: origin lockdown behind Cloudflare ---
# Leave false until the chatbot DNS record is orange-clouded (proxied) in Cloudflare
# and verified. When true, the playbook restricts inbound 80/443 to Cloudflare's IP
# ranges and makes nginx read the real client IP from CF-Connecting-IP. Flipping it
# before the DNS is proxied locks the origin out. SSH (22) is unaffected.
# restrict_http_to_cloudflare=false

# --- Abuse and cost controls (optional; these are the defaults) ---
# daily_spend_limit_usd=5.0
# daily_spend_limit_per_ip_usd=0.50
# spend_alert_threshold=0.70
# rate_limit_enabled=true
# rate_limit_per_minute=10
# rate_limit_per_hour=100
# max_message_length=1000

# --- Agent tools (see tools.py) ---
# wbcrm_api_token is NOT set here — it's generated in the CRM and stored as a secret
# (GitHub secret WBCRM_API_TOKEN and, for local runs, the gitignored inventory.ini).
# wbcrm_base_url=http://wb-crm-backend:3010   # internal; chatbot is on the wb-crm network
# lead_source_group=bot
# booking_url=https://agenda.wbdigitalsolutions.com/book
# whatsapp_contact=(11) 98286-4581
# Evolution (WhatsApp notify) — optional; blank skips the notify:
# evolution_api_url=
# evolution_api_key=
# evolution_instance=
# my_whatsapp_number=